          "L_GLU_120",
          "L_GLU120"
        ]
      },
      "androgens_optional": {
        "tt_optional": [
          "Testosteron (L_TESTOS)",
          "L_TESTOS",
          "TESTOS",
          "TESTOSTERON",
          "TESTO"
        ],
        "ft_optional": [
          "Testosteron wolny (O41) (TEST-F)",
          "TEST-F",
          "TEST_F",
          "TESTF",
          "Wolny testosteron"
        ],
        "shbg_optional": [
          "SHBG (SHGB)",
          "SHBG",
          "SHGB",
          "L_SHBG",
          "L_SHGB"
        ],
        "dheas_optional": [
          "DHEAS (DHEA)",
          "DHEAS",
          "DHEA-S",
          "DHEA_S",
          "L_DHEA",
          "L_DHEAS"
        ],
        "andro_optional": [
          "Androstendion (ANDRO)",
          "ANDRO"
        ],
        "amh_optional": [
          "AMH-anty Mullerian Hormon (AMH)",
          "AMH",
          "L_AMH"
        ],
        "lh_optional": [
          "LH  (LH)",
          "LH",
          "L_LH"
        ],
        "fsh_optional": [
          "FSH (FSH)",
          "FSH",
          "L_FSH"
        ]
      },
      "insulin_optional": {
        "ins0_optional": [
          "INS0",
          "INS_0",
